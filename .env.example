# --- Spotify (OAuth Authorization Code + PKCE) ---
# Create an app at https://developer.spotify.com/dashboard
# Add http://127.0.0.1:8888/callback as a Redirect URI.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Minted once by scripts/spotify_login.py — store as a secret afterwards.
SPOTIFY_REFRESH_TOKEN=
# Redirect URI registered on the Spotify app (must match exactly).
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- Gig sources (added in later milestones) ---
TICKETMASTER_API_KEY=
BANDSINTOWN_APP_ID=
SKIDDLE_API_KEY=

# --- Fragile scrapers (kill switches) ---
RA_ENABLED=true
DICE_ENABLED=true

# --- Email (added in milestone 5) ---
EMAIL_TO=
EMAIL_FROM=
RESEND_API_KEY=

# --- Behaviour ---
LOOKAHEAD_DAYS=90
# SQLite database path.
DB_PATH=gig_radar.db
